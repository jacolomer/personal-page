labs(
title    = "Autoidentificación de clase social en España, 2011-2025",
subtitle = paste0(
"Mismo color = categoría conceptualmente equivalente entre formatos.\n",
"El cambio a pregunta espontánea en 2020 hace emerger la 'clase trabajadora/obrera'."
),
x = NULL, y = "% (ponderado, sobre válidos)",
caption  = paste0(
"Fuente: CIS (Encuestas de Política Fiscal 2011-2025 y Barómetro Julio 2020).\n",
"% sobre respuestas válidas (excluye NS/NC). Datos ponderados."
)
) +
tema_base +
theme(legend.position = "bottom", legend.box = "vertical")
save_fig(fig1, "fig1_evolucion_clase", w = 13, h = 7)
cat("✓ Figura 1 guardada\n")
# =============================================================================
# FIGURA 2 — Tasas de NS/NC a lo largo del tiempo
# =============================================================================
# La pregunta abierta puede generar más NS/NC y respuestas atípicas ("Otras").
fig2 <- nsnc_estudio |>
ggplot(aes(x = anyo, y = pct_NS_NC, color = tipo_pregunta,
shape = tipo_pregunta, group = tipo_pregunta)) +
geom_line(linewidth = 1) +
geom_point(size = 3) +
# Añadir tasa de "Otras" para el período abierto
geom_point(data = filter(nsnc_estudio, tipo_pregunta == "abierta"),
aes(y = pct_NS_NC + pct_otras),
shape = 2, size = 3, alpha = 0.5) +
geom_line(data = filter(nsnc_estudio, tipo_pregunta == "abierta"),
aes(y = pct_NS_NC + pct_otras),
linetype = "dotted", linewidth = 0.8, alpha = 0.5) +
annotate("text", x = 2022.5, y = 0.08,
label = "NS/NC + 'Otras'\n(pregunta abierta)", size = 3, color = "grey40") +
scale_x_continuous(breaks = seq(2011, 2025, 2)) +
scale_y_continuous(labels = percent_format(accuracy = 0.1), limits = c(0, 0.15)) +
scale_color_manual(values = c("cerrada" = "#08519c", "abierta" = "#810f7c"),
labels = c("cerrada" = "Cerrada (con tarjeta)",
"abierta" = "Abierta (espontánea)")) +
scale_shape_manual(values = c("cerrada" = 16, "abierta" = 17),
labels = c("cerrada" = "Cerrada (con tarjeta)",
"abierta" = "Abierta (espontánea)")) +
geom_vline(xintercept = 2020.3, linetype = "dashed", color = "grey50") +
annotate("text", x = 2020.5, y = 0.14,
label = "Cambio de\nformato", size = 3, hjust = 0, color = "grey40") +
labs(
title   = "Tasa de NS/NC por formato de pregunta (2011-2025)",
subtitle = "¿La pregunta abierta genera más respuestas atípicas?",
x = NULL, y = "Proporción NS/NC",
caption = "Fuente: CIS. Datos ponderados (peso=1 en estudios sin ponderación)."
) +
tema_base
save_fig(fig2, "fig2_nsnc_tiempo", w = 10, h = 5.5)
cat("✓ Figura 2 guardada\n")
# =============================================================================
# FIGURA 3 — Experimento natural: julio 2020
# E3290 (Política Fiscal, cerrada) vs. E3288 (Barómetro, abierta)
# ~10 días de diferencia de campo, misma población
# =============================================================================
# Calcular directamente desde df (no depende de dist_estudio, que filtra clase_valida
# y podría perder E3288 si su recode de peso o clase fue diferente).
datos_exp3 <- df |>
filter(estudio_id %in% c("E3290", "E3288"), clase_valida, !is.na(peso)) |>
group_by(estudio_id, tipo_pregunta, clase_social_lbl) |>
summarise(w = sum(peso), .groups = "drop") |>
group_by(estudio_id) |>
mutate(pct = w / sum(w)) |>
ungroup()
cat("Estudios en experimento natural (E3290 y E3288):\n")
print(table(datos_exp3$estudio_id))
if (n_distinct(datos_exp3$estudio_id) < 2) {
cat("\n⚠  AVISO: solo hay datos de uno de los dos estudios.\n")
cat("   Verifica que E3288 esté en el dataset y tenga clase_valida == TRUE.\n")
cat("   Diagnóstico rápido:\n")
cat("     df |> filter(estudio_id == 'E3288') |> count(clase_valida)\n\n")
}
datos_exp3 <- datos_exp3 |>
mutate(
formato_lbl = case_when(
estudio_id == "E3290" ~ "Cerrada (E3290)\nPolítica Fiscal · jul. 2020",
estudio_id == "E3288" ~ "Abierta (E3288)\nBarómetro · jul. 2020"
),
formato_lbl = factor(formato_lbl,
levels = c("Cerrada (E3290)\nPolítica Fiscal · jul. 2020",
"Abierta (E3288)\nBarómetro · jul. 2020")),
clase_f = factor(clase_social_lbl, levels = c(
"Alta", "Media-alta", "Alta y media-alta",
"Media", "Media-media", "Media-baja",
"Trabajadora/obrera", "Baja", "Baja/pobre"
))
)
fig3 <- datos_exp3 |>
ggplot(aes(x = clase_f, y = pct, fill = clase_f)) +
geom_col(width = 0.7, show.legend = FALSE) +
geom_text(aes(label = percent(pct, accuracy = 0.1)),
vjust = -0.4, size = 3.8, fontface = "bold") +
scale_fill_manual(values = COL_SERIES) +
scale_y_continuous(labels = percent_format(accuracy = 1),
limits = c(0, 0.70)) +
scale_x_discrete(labels = function(x) str_wrap(x, 12),
drop = FALSE) +
facet_wrap(~ formato_lbl, scales = "free_x") +
labs(
title    = "Experimento natural: julio 2020",
subtitle = paste0(
"Misma población, ~10 días de diferencia de campo, distinto formato de pregunta.\n",
"La categoría 'Trabajadora/obrera' solo puede emerger en el formato espontáneo."
),
x = NULL, y = "% ponderado (sobre válidos)",
caption  = paste0(
"E3290 (Política Fiscal, cerrada): campo jul. 2020 | ",
"E3288 (Barómetro, abierta): campo jul. 2020.\n",
"Datos ponderados. El eje X de cada panel muestra solo las categorías disponibles en ese formato."
)
) +
tema_base +
theme(axis.text.x = element_text(size = 9))
save_fig(fig3, "fig3_experimento_natural", w = 11, h = 6)
cat("✓ Figura 3 guardada\n")
# =============================================================================
# FIGURA 4 — ¿De dónde viene la clase trabajadora?
# Perfil socioeconómico comparado entre categorías y formatos
# =============================================================================
# Comparación: perfil de CLASESUB=4 (Trabajadora, abierta) vs.
# CLASESUB=3 (Media-baja, cerrada) y CLASESUB=5 (Baja, cerrada)
# Si los perfiles de Trabajadora se parecen a Media-baja (cerrada),
# sugiere que el formato la había absorbido en esa categoría.
# Función auxiliar: varianza ponderada (debe estar definida antes de su uso)
wtd_var <- function(x, w) {
keep <- !is.na(x) & !is.na(w)
x <- x[keep]; w <- w[keep]
w <- w / sum(w)
xm <- sum(w * x)
sum(w * (x - xm)^2)
}
perfiles <- df |>
filter(
clase_valida, !is.na(peso),
# Solo categorías de interés
(tipo_pregunta == "cerrada" & clase_social_lbl %in%
c("Media", "Media-baja", "Baja")) |
(tipo_pregunta == "abierta"  & clase_social_lbl %in%
c("Media-media", "Media-baja", "Trabajadora/obrera", "Baja/pobre")),
!is.na(ideologia_harm),
!is.na(estudios_harm),
!is.na(sexo)
) |>
mutate(
cat_perfil = factor(clase_social_lbl, levels = c(
"Media", "Media-media",
"Media-baja",
"Trabajadora/obrera",
"Baja", "Baja/pobre"
)),
fmt_lbl = if_else(tipo_pregunta == "cerrada",
"Cerrada (2011-2020)", "Abierta (2020-2025)")
)
# Media ponderada de ideología, educación y género por categoría y formato
perfil_stats <- perfiles |>
group_by(fmt_lbl, cat_perfil) |>
summarise(
n            = n(),
ideol_media  = weighted.mean(ideologia_harm, w = peso, na.rm = TRUE),
ideol_se     = sqrt(wtd_var(ideologia_harm, peso)),
pct_sup      = weighted.mean(estudios_harm == 5, w = peso, na.rm = TRUE),
pct_sinest   = weighted.mean(estudios_harm <= 2, w = peso, na.rm = TRUE),
pct_mujer    = weighted.mean(sexo == 2, w = peso, na.rm = TRUE),
edad_media   = weighted.mean(edad, w = peso, na.rm = TRUE),
.groups = "drop"
) |>
filter(!is.na(cat_perfil))
# Gráfico: ideología media por categoría y formato
col_perfil <- c(
"Media"              = "#41ab5d",
"Media-media"        = "#41ab5d",
"Media-baja"         = "#fe9929",
"Trabajadora/obrera" = "#810f7c",
"Baja"               = "#cc4c02",
"Baja/pobre"         = "#cc4c02"
)
shape_perfil <- c(
"Cerrada (2011-2020)" = 16,
"Abierta (2020-2025)" = 17
)
p4a <- perfil_stats |>
ggplot(aes(x = cat_perfil, y = ideol_media,
color = cat_perfil, shape = fmt_lbl)) +
geom_point(size = 4, position = position_dodge(0.4)) +
geom_errorbar(aes(ymin = ideol_media - ideol_se,
ymax = ideol_media + ideol_se),
width = 0.2, position = position_dodge(0.4)) +
scale_color_manual(values = col_perfil, guide = "none") +
scale_shape_manual(values = shape_perfil) +
scale_x_discrete(labels = function(x) str_wrap(x, 12)) +
labs(title = "Posición ideológica media", x = NULL, y = "Escala 1-10",
shape = NULL) +
tema_base + theme(legend.position = "top")
p4b <- perfil_stats |>
ggplot(aes(x = cat_perfil, y = pct_sup,
color = cat_perfil, shape = fmt_lbl)) +
geom_point(size = 4, position = position_dodge(0.4)) +
scale_color_manual(values = col_perfil, guide = "none") +
scale_shape_manual(values = shape_perfil, guide = "none") +
scale_y_continuous(labels = percent_format(accuracy = 1)) +
scale_x_discrete(labels = function(x) str_wrap(x, 12)) +
labs(title = "% con estudios superiores", x = NULL, y = NULL) +
tema_base
p4c <- perfil_stats |>
ggplot(aes(x = cat_perfil, y = pct_mujer,
color = cat_perfil, shape = fmt_lbl)) +
geom_point(size = 4, position = position_dodge(0.4)) +
scale_color_manual(values = col_perfil, guide = "none") +
scale_shape_manual(values = shape_perfil, guide = "none") +
scale_y_continuous(labels = percent_format(accuracy = 1)) +
scale_x_discrete(labels = function(x) str_wrap(x, 12)) +
labs(title = "% mujeres", x = NULL, y = NULL) +
tema_base
fig4 <- (p4a | p4b | p4c) +
plot_annotation(
title    = "¿De dónde viene la 'clase trabajadora'? Perfiles comparados",
subtitle = paste0(
"Triángulos = pregunta abierta (2020-2025) | Círculos = pregunta cerrada (2011-2020)\n",
"Si el perfil de 'Trabajadora/obrera' se parece al de 'Media-baja' (cerrada),\n",
"sugiere que el formato cerrado absorbía esa identidad."
),
caption = "Fuente: CIS. Datos ponderados. Barras: ±1 desviación estándar ponderada.",
theme   = tema_base
)
save_fig(fig4, "fig4_perfil_trabajadora", w = 14, h = 6)
cat("✓ Figura 4 guardada\n")
# =============================================================================
# FIGURA 5 — Distribución de ideología por clase y formato
# =============================================================================
# Panel izquierdo: período ABIERTO (2020-2025), escala 1-10 uniforme.
# Panel derecho:   período CERRADO solo con estudios escala 1-10
#                  (2011, 2019, 2020 — excluye 2012-2017 que usan escala 0-10).
# Hipótesis: izquierda → Media-baja/Baja (cerrada) ≈ Trabajadora (abierta).
ideol_abierta <- df |>
filter(
tipo_pregunta == "abierta",
clase_valida, !is.na(ideologia_harm), !is.na(peso),
clase_social_lbl %in% c("Alta y media-alta", "Media-media", "Media-baja",
"Trabajadora/obrera", "Baja/pobre")
) |>
mutate(
clase_f  = factor(clase_social_lbl,
levels = rev(c("Alta y media-alta", "Media-media",
"Media-baja", "Trabajadora/obrera",
"Baja/pobre"))),
fmt_lbl  = "Abierta (2020-2025)"
)
# Para la cerrada usamos SOLO estudios con escala 1-10 (2011, 2019, 2020)
# para evitar el artefacto de mezclar escalas 0-10 y 1-10.
ideol_cerrada <- df |>
filter(
tipo_pregunta == "cerrada",
ideologia_escala == "1-10",           # Solo escala comparable
clase_valida, !is.na(ideologia_harm), !is.na(peso),
clase_social_lbl %in% c("Media", "Media-baja", "Baja")
) |>
mutate(
clase_f  = factor(clase_social_lbl,
levels = rev(c("Media", "Media-baja", "Baja"))),
fmt_lbl  = "Cerrada (2011, 2019-2020)\nescala 1-10"
)
ideol_all5 <- bind_rows(ideol_abierta, ideol_cerrada) |>
mutate(fmt_lbl = factor(fmt_lbl,
levels = c("Abierta (2020-2025)",
"Cerrada (2011, 2019-2020)\nescala 1-10")))
col_ridges <- c(
"Alta y media-alta"  = "#4292c6",
"Media-media"        = "#41ab5d",
"Media"              = "#41ab5d",
"Media-baja"         = "#fe9929",
"Trabajadora/obrera" = "#810f7c",
"Baja/pobre"         = "#cc4c02",
"Baja"               = "#cc4c02"
)
fig5 <- ideol_all5 |>
ggplot(aes(x = ideologia_harm, y = clase_f,
fill = clase_f, weight = peso)) +
geom_density_ridges(alpha = 0.75, scale = 0.88,
quantile_lines = TRUE, quantiles = 2,
bandwidth = 0.6) +
scale_fill_manual(values = col_ridges, guide = "none") +
scale_x_continuous(breaks = c(1, 3, 5, 7, 10),
labels = c("1\n(izda.)", "3", "5", "7", "10\n(dcha.)"),
limits = c(0.5, 11)) +
scale_y_discrete(labels = function(x) str_wrap(x, 16)) +
facet_wrap(~ fmt_lbl, scales = "free_y") +
labs(
title    = "Distribución ideológica dentro de cada clase autoidentificada",
subtitle = paste0(
"La 'clase trabajadora/obrera' se concentra más a la izquierda que 'media-baja' en la misma escala.\n",
"Nota: período cerrado muestra solo estudios con escala 1-10 (2011, 2019-2020) para comparabilidad."
),
x = "Escala ideológica (1 = izquierda, 10 = derecha)", y = NULL,
caption  = "Fuente: CIS. Datos ponderados. Línea vertical: mediana."
) +
tema_base + theme(legend.position = "none")
save_fig(fig5, "fig5_ideologia_clase", w = 13, h = 7)
cat("✓ Figura 5 guardada\n")
# =============================================================================
# MODELOS — Predictores de la autoidentificación de clase
# =============================================================================
# Dos modelos multinomiales logísticos (uno por formato).
# Predictores: ideología, educación (4 cats), género, grupo de edad.
# Efectos fijos de año.
# Ref. cerrada: "Media" | Ref. abierta: "Media-media"
#
# NOTA: ideología en escala 0-10 (2012-2017) vs 1-10 (resto). Para el modelo
# cerrado se incluyen todos los años; interpretar el coeficiente de ideología
# como "mayor posición en la escala disponible → más a la derecha".
# El período abierto usa uniformemente escala 1-10.
df_modelo <- df |>
filter(
clase_valida,
!is.na(ideologia_harm), !is.na(estudios_harm),
!is.na(sexo), !is.na(edad_grupo)
) |>
mutate(
clase_cerrada = factor(clase_social_lbl,
levels = c("Media", "Alta", "Media-alta",
"Media-baja", "Baja")),
clase_abierta = factor(clase_social_lbl,
levels = c("Media-media", "Alta y media-alta",
"Media-baja", "Trabajadora/obrera",
"Baja/pobre")),
educ4 = case_when(
estudios_harm <= 2 ~ 1L,
estudios_harm == 3 ~ 2L,
estudios_harm == 4 ~ 3L,
estudios_harm == 5 ~ 4L
),
educ4_f = factor(educ4, labels = c("Primaria o menos", "Secundaria",
"FP", "Superiores")),
mujer   = as.integer(sexo == 2L),
anyo_f  = factor(anyo)
)
# ── Modelo cerrada ─────────────────────────────────────────────────────────────
cat("\nAjustando modelo cerrada (2011-2020)...\n")
df_cerrada_m <- df_modelo |>
filter(tipo_pregunta == "cerrada", !is.na(clase_cerrada))
m_cerrada <- multinom(
clase_cerrada ~ ideologia_harm + educ4_f + mujer + edad_grupo_f + anyo_f,
data    = df_cerrada_m,
weights = peso,
trace   = FALSE,
maxit   = 500
)
cat("  Convergencia OK. N =", nrow(df_cerrada_m), "\n")
# ── Modelo abierta ─────────────────────────────────────────────────────────────
cat("Ajustando modelo abierta (2020-2025)...\n")
df_abierta_m <- df_modelo |>
filter(tipo_pregunta == "abierta", !is.na(clase_abierta))
m_abierta <- multinom(
clase_abierta ~ ideologia_harm + educ4_f + mujer + edad_grupo_f + anyo_f,
data    = df_abierta_m,
weights = peso,
trace   = FALSE,
maxit   = 500
)
cat("  Convergencia OK. N =", nrow(df_abierta_m), "\n")
# =============================================================================
# FIGURA 6 — Coeficientes de ideología: cerrada vs. abierta
# =============================================================================
# Forest plot comparando el coeficiente de ideología para cada clase en
# ambos formatos. Pregunta clave: ¿la ideología de izquierda predice
# "Trabajadora" (abierta) igual que predecía "Media-baja" (cerrada)?
# tidy() con conf.int=TRUE usa confint() (verosimilitud perfilada) sobre
# multinom(), lo que puede fallar. Calculamos IC desde el error estándar (Wald).
coef_cerrada <- tidy(m_cerrada, conf.int = FALSE) |>
filter(term == "ideologia_harm") |>
mutate(
conf.low  = estimate - 1.96 * std.error,
conf.high = estimate + 1.96 * std.error,
formato   = "Cerrada (2011-2020)",
ref_cat   = "Ref: Media"
)
predict_probs <- function(modelo, formato, clases_ref) {
ideol_seq <- seq(1, 10, by = 0.5)
# Perfil de referencia: mujer=0, educ=Secundaria, edad=35-44, año modal
anyo_modal <- df_modelo |>
filter(tipo_pregunta == formato) |>
count(anyo) |> slice_max(n, n = 1) |> pull(anyo) |> as.character()
nd <- tibble(
ideologia_harm = ideol_seq,
educ4_f        = factor("Secundaria",
levels = levels(df_modelo$educ4_f)),
mujer          = 0L,
edad_grupo_f   = factor("35-44",
levels = levels(df_modelo$edad_grupo_f)),
anyo_f         = factor(anyo_modal,
levels = levels(df_modelo$anyo_f))
)
probs <- predict(modelo, newdata = nd, type = "probs") |>
as_tibble() |>
mutate(ideologia_harm = ideol_seq, formato = formato)
pivot_longer(probs, -c(ideologia_harm, formato),
names_to = "clase", values_to = "prob")
}
pp_cerrada <- predict_probs(m_cerrada, "cerrada",
c("Media","Alta","Media-alta","Media-baja","Baja"))
pp_abierta <- predict_probs(m_abierta, "abierta",
c("Media-media","Alta y media-alta","Media-baja",
"Trabajadora/obrera","Baja/pobre"))
pp_all <- bind_rows(pp_cerrada, pp_abierta) |>
mutate(
formato_lbl = if_else(formato == "cerrada",
"Cerrada (2011-2020)", "Abierta (2020-2025)"),
col_cat = case_when(
clase %in% c("Alta", "Alta y media-alta", "Media-alta") ~ "#4292c6",
clase %in% c("Media", "Media-media")                    ~ "#41ab5d",
clase == "Media-baja"                                   ~ "#fe9929",
clase == "Trabajadora/obrera"                           ~ "#810f7c",
clase %in% c("Baja", "Baja/pobre")                     ~ "#cc4c02",
TRUE ~ "grey50"
)
)
fig7 <- pp_all |>
ggplot(aes(x = ideologia_harm, y = prob, color = col_cat, group = clase)) +
geom_line(linewidth = 1.1) +
geom_text(
data = pp_all |> group_by(formato, clase) |> slice_max(ideologia_harm),
aes(label = str_wrap(clase, 12)), hjust = -0.05, size = 2.8
) +
scale_color_identity() +
scale_x_continuous(breaks = 1:10, limits = c(1, 12)) +
scale_y_continuous(labels = percent_format(accuracy = 1), limits = c(0, 0.7)) +
facet_wrap(~ formato_lbl) +
labs(
title    = "Probabilidades predichas de autoidentificación de clase según ideología",
subtitle = "Perfil de referencia: hombre, estudios secundarios, 35-44 años.",
x = "Escala ideológica (1 = izquierda, 10 = derecha)",
y = "Probabilidad predicha",
caption  = "Modelo multinomial logístico. Intervalo de confianza no incluido por legibilidad."
) +
tema_base + theme(legend.position = "none")
save_fig(fig7, "fig7_prob_predichas_ideologia", w = 13, h = 6)
cat("✓ Figura 7 guardada\n")
# =============================================================================
# TABLA 1 — Estadísticos descriptivos por formato y clase
# =============================================================================
tab1_data <- df |>
filter(clase_valida, !is.na(peso)) |>
mutate(fmt_lbl = if_else(tipo_pregunta == "cerrada",
"Cerrada", "Abierta")) |>
group_by(fmt_lbl, clase_social_lbl) |>
summarise(
N           = n(),
pct         = round(100 * sum(peso) /
sum(df$peso[df$tipo_pregunta == first(tipo_pregunta) &
df$clase_valida], na.rm = TRUE), 1),
ideol_media = round(weighted.mean(ideologia_harm, peso, na.rm = TRUE), 2),
pct_sup     = round(100 * weighted.mean(estudios_harm == 5, peso, na.rm = TRUE), 1),
pct_mujer   = round(100 * weighted.mean(sexo == 2, peso, na.rm = TRUE), 1),
.groups     = "drop"
) |>
arrange(fmt_lbl, desc(pct))
write_csv(tab1_data, file.path(DIR_TAB, "tab1_descriptivos.csv"))
tab1_gt <- tab1_data |>
gt(groupname_col = "fmt_lbl") |>
cols_label(
clase_social_lbl = "Categoría de clase",
N                = "N",
pct              = "% (pond.)",
ideol_media      = "Ideología media",
pct_sup          = "% Superiores",
pct_mujer        = "% Mujer"
) |>
tab_header(
title    = "Tabla 1. Descriptivos por formato de pregunta y clase autoidentificada",
subtitle = "CIS 2011-2025. Datos ponderados."
) |>
tab_footnote("Ideología: 1 (izquierda) — 10 (derecha). Escala 0-10 en estudios 2012-2017.") |>
tab_style(style = cell_text(weight = "bold"),
locations = cells_row_groups())
gtsave(tab1_gt, file.path(DIR_TAB, "tab1_descriptivos.html"))
cat("✓ Tabla 1 guardada\n")
# =============================================================================
# TABLA 2 — Resultados de los modelos multinomiales
# =============================================================================
modelos <- list(
"Cerrada (ref: Media)"        = m_cerrada,
"Abierta (ref: Media-media)"  = m_abierta
)
tab2 <- modelsummary(
modelos,
exponentiate = FALSE,
statistic    = "conf.int",
coef_omit    = "anyo_f",
coef_rename  = c(
"ideologia_harm"                  = "Ideología (→ derecha)",
"educ4_fSecundaria"               = "Educación: Secundaria",
"educ4_fFP"                       = "Educación: FP",
"educ4_fSuperiores"               = "Educación: Superiores",
"mujer"                           = "Mujer",
"edad_grupo_f25-34"               = "Edad: 25-34",
"edad_grupo_f35-44"               = "Edad: 35-44",
"edad_grupo_f45-54"               = "Edad: 45-54",
"edad_grupo_f55-64"               = "Edad: 55-64",
"edad_grupo_f65+"                 = "Edad: 65+"
),
notes        = c(
"Coeficientes log-odds del modelo multinomial logístico.",
"Efectos fijos de año incluidos pero no mostrados.",
"IC 95% entre paréntesis. Datos ponderados.",
"Ref. educación: Primaria o menos. Ref. edad: 18-24."
),
output       = file.path(DIR_TAB, "tab2_modelos.html")
)
summary(m_abierta)
